<?xml version="1.0" encoding="UTF-8"?>
<!--
  Spring Boot Logging 模块 Logback 配置文件

  功能特性：
  - 支持控制台和文件日志输出
  - 分布式链路追踪 trace ID 集成
  - 异步日志写入提升性能
  - 日志文件自动滚动和清理
  - JSON 格式日志输出，便于日志分析和处理
  - 不同环境的日志级别配置

  文档地址：https://logback.qos.ch/manual/configuration.html
-->
<configuration>

    <!-- ==================== 配置变量定义 ==================== -->

    <!--
      应用程序日志级别，通过 application-*.yml 中 logging.level.<base-package> 控制
      com.example 为示例包名，实际使用时替换为项目的根包名
    -->
    <springProperty scope="context" name="APP_LOG_LEVEL" source="logging.level.com.example" defaultValue="INFO"/>

    <!-- 日志文件存储目录，默认为应用工作目录下的 logs 子目录，生产环境通过 application-prod.yml 覆盖为绝对路径 -->
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="./logs"/>

    <!-- ==================== 控制台彩色日志配置 ==================== -->

    <!-- 彩色日志转换规则定义 -->
    <conversionRule conversionWord="clr" class="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex"
                    class="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>
    <conversionRule conversionWord="wEx"
                    class="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter"/>

    <!--
      控制台彩色日志格式
      时间戳(淡色) 日志级别 进程ID(洋红色) - [线程名](淡色) [trace ID,span ID](黄色) Logger名称(青色) : 消息
      各部分使用不同颜色便于快速识别
    -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr([%X{traceId:-},%X{spanId:-}]){yellow} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <!-- ==================== Appender 配置 ==================== -->

    <!--
      控制台日志输出 Appender
      开发环境下实时查看日志信息，使用彩色格式便于快速识别不同级别的日志
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- 使用彩色日志格式 -->
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <!-- 设置字符编码为 UTF-8 -->
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--
      主日志文件 Appender (同步)
      记录 INFO 及以上所有级别日志（INFO、WARN、ERROR）
      滚动策略参数为示例值，生产环境按业务量调整：单个文件最大 5MB，保留 30 天，总大小上限 1GB
      使用 JSON 格式输出，便于日志分析和处理
    -->
    <appender name="FILE_SYNC" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前日志文件路径 -->
        <file>${LOG_PATH}/app.log</file>
        <!-- 文件滚动策略：按日期和大小滚动 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 滚动文件命名格式：app.2024-01-01.0.log -->
            <fileNamePattern>${LOG_PATH}/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个文件最大大小 -->
            <maxFileSize>5MB</maxFileSize>
            <!-- 保留历史文件天数 -->
            <maxHistory>30</maxHistory>
            <!-- 所有文件总大小限制 -->
            <totalSizeCap>1GB</totalSizeCap>
            <!-- 启动时清理过期文件 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <!-- 使用 JSON 格式化器，将 traceId、spanId、clientIp 提升到顶级，便于日志分析平台检索 -->
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <!-- 时间戳字段 -->
                <timestamp>
                    <fieldName>timestamp</fieldName>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</pattern>
                </timestamp>
                <!-- 日志级别字段 -->
                <logLevel>
                    <fieldName>level</fieldName>
                </logLevel>
                <!-- 线程名字段 -->
                <threadName>
                    <fieldName>thread</fieldName>
                </threadName>
                <!-- Logger 名称字段 -->
                <loggerName>
                    <fieldName>logger</fieldName>
                </loggerName>
                <!-- 消息字段 -->
                <message/>
                <!-- MDC 字段：提取 traceId、spanId、clientIp 到顶级 -->
                <mdc>
                    <includeMdcKeyName>traceId</includeMdcKeyName>
                    <includeMdcKeyName>spanId</includeMdcKeyName>
                    <includeMdcKeyName>clientIp</includeMdcKeyName>
                </mdc>
                <!-- 异常堆栈字段 -->
                <stackTrace>
                    <fieldName>stackTrace</fieldName>
                </stackTrace>
            </providers>
        </encoder>
    </appender>

    <!-- ==================== 异步 Appender 配置 ==================== -->

    <!--
      主日志文件异步 Appender
      通过异步写入提升日志记录性能，避免阻塞业务线程
    -->
    <appender name="FILE" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 队列大小 512，平衡内存使用和性能；队列满时丢弃低级别日志，不阻塞业务线程 -->
        <queueSize>512</queueSize>
        <!-- 队列满时不阻塞调用线程 -->
        <neverBlock>true</neverBlock>
        <!-- 不包含调用者信息，提升性能 -->
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FILE_SYNC"/>
    </appender>

    <!-- ==================== 应用程序 Logger 配置 ==================== -->

    <!--
      应用程序日志配置
      com.example 包的日志级别由各环境的 application-*.yml 中 logging.level.com.example 控制
    -->
    <logger name="com.example" level="${APP_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- ==================== 根 Logger 配置 ==================== -->

    <!--
      根日志配置
      固定 INFO 级别，控制第三方库日志输出
    -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
